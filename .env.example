# ═══════════════════════════════════════════════════════════
# BELLUM MUNDI — ENVIRONMENT VARIABLES
# Copy this to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════

# Supabase (Public — safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role (NEVER expose to browser — server only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI - Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Stripe Price IDs — Commander plan (€12.99/mo · €94.99/yr)
NEXT_PUBLIC_STRIPE_PRICE_COMMANDER_MONTHLY=price_commander_monthly_id_here
NEXT_PUBLIC_STRIPE_PRICE_COMMANDER_ANNUAL=price_commander_annual_id_here

# Stripe Price IDs — Educator plan (€19.99/mo · €149.99/yr)
NEXT_PUBLIC_STRIPE_PRICE_EDU_MONTHLY=price_edu_monthly_id_here
NEXT_PUBLIC_STRIPE_PRICE_EDU_ANNUAL=price_edu_annual_id_here

# Image Search (Unsplash or similar)
UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# App URL
NEXT_PUBLIC_APP_URL=https://bellummundi.com

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
