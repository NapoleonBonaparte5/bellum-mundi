# Supabase (Public — safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://ynxzhtkmxuwznnajmnyu.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase Service Role (NEVER expose to browser — server only)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# AI - Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_key_here

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Stripe Price IDs
STRIPE_PRICE_MONTHLY=price_monthly_id_here
STRIPE_PRICE_ANNUAL=price_annual_id_here

# Image Search (Unsplash or similar)
UNSPLASH_ACCESS_KEY=your_unsplash_key_here

# App URL
NEXT_PUBLIC_APP_URL=https://bellummundi.com

# Google Analytics
NEXT_PUBLIC_GA_ID=G-1DNHLE647Z
